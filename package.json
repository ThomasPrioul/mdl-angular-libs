{
  "name": "mdl-angular",
  "version": "2.0.0",
  "scripts": {
    "start": "npm-run-all clean --parallel lib:watch showcase:start-waiton",
    "start:md3": "npm-run-all clean --parallel lib:watch showcase:start:md3-waiton",
    "build": "run-s lib:build showcase:build",
    "test": "run-p lib:test showcase:test test:styles",
    "test:styles": "vitest run --config vitest.styles.config.ts",
    "lib:build": "nx build mdl-angular",
    "lib:watch": "nx build mdl-angular --watch --configuration development",
    "lib:test": "nx test mdl-angular",
    "showcase:start-waiton": "wait-on dist/mdl-angular/zoom-button/package.json && npm run showcase:start",
    "showcase:start": "nx serve showcase",
    "showcase:start:md3-waiton": "wait-on dist/mdl-angular/zoom-button/package.json && npm run showcase:start:md3",
    "showcase:start:md3": "nx serve showcase --configuration=md3",
    "showcase:build": "nx build showcase",
    "showcase:watch": "nx build showcase --watch --configuration development",
    "showcase:test": "nx test showcase",
    "clean": "rimraf dist",
    "gh-pages": "nx build showcase --output-path docs --base-href /mdl-angular-libs/ && mv docs/browser/* docs",
    "publish": "npm run lib:build && cp README.md dist/mdl-angular/ && npm publish dist/mdl-angular/"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "21.2.9",
    "@angular/cdk": "21.2.9",
    "@angular/common": "21.2.9",
    "@angular/compiler": "21.2.9",
    "@angular/core": "21.2.9",
    "@angular/forms": "21.2.9",
    "@angular/material": "21.2.9",
    "@angular/material-luxon-adapter": "21.2.9",
    "@angular/platform-browser": "21.2.9",
    "@angular/platform-browser-dynamic": "21.2.9",
    "@angular/router": "21.2.9",
    "luxon": "^3.4.4",
    "luxon-angular": "^6.0.0",
    "rxjs": "~7.8.1",
    "tslib": "^2.6.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "21.2.9",
    "@angular-devkit/core": "21.2.9",
    "@angular-devkit/schematics": "21.2.9",
    "@angular/build": "21.2.9",
    "@angular/cli": "21.2.9",
    "@angular/compiler-cli": "21.2.9",
    "@nx/angular": "22.7.2",
    "@nx/workspace": "22.7.2",
    "@schematics/angular": "^21.0.0",
    "@types/jasmine": "~5.1.4",
    "@types/luxon": "^3.4.2",
    "@vitest/coverage-v8": "^4.0.0",
    "autoprefixer": "^10.4.17",
    "jasmine-core": "~5.1.1",
    "jsdom": "^29.1.1",
    "karma": "~6.4.2",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "21.2.3",
    "npm-run-all": "^4.1.5",
    "nx": "22.7.2",
    "postcss": "^8.4.33",
    "prettier": "~3.6.2",
    "rimraf": "^5.0.5",
    "tailwindcss": "^3.4.1",
    "typescript": "~5.9.0",
    "vitest": "^4.0.0",
    "wait-on": "^7.2.0",
    "zone.js": "^0.16.2"
  }
}
